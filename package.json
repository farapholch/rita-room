{
  "type": "module",
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "debug": "4.4.3",
    "dotenv": "^17.4.2",
    "express": "5.2.1",
    "ioredis": "^5.10.1",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.3",
    "socket.io-adapter": "^2.5.6"
  },
  "devDependencies": {
    "@excalidraw/eslint-config": "1.0.3",
    "@excalidraw/prettier-config": "1.0.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/debug": "4.1.13",
    "@types/express": "5.0.6",
    "@types/node": "25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.1",
    "c8": "^11.0.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "cross-env": "10.1.0",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "socket.io-client": "^4.8.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "5.9.3"
  },
  "resolutions": {
    "braces": "^3.0.3"
  },
  "license": "MIT",
  "main": "dist/index.js",
  "name": "excalidraw-portal",
  "prettier": "@excalidraw/prettier-config",
  "scripts": {
    "build": "tsc",
    "fix:code": "yarn test:code --fix",
    "fix:other": "yarn prettier --write",
    "fix": "yarn fix:other && yarn fix:code",
    "prettier": "prettier . --ignore-path=.gitignore",
    "start": "node dist/index.js",
    "start:dev": "cross-env NODE_ENV=development ts-node-dev --respawn --transpile-only src/index.ts",
    "test:code": "eslint --ext .ts .",
    "test:other": "yarn prettier --list-different || echo '⚠️ Prettier found formatting issues'",
    "test": "yarn test:other && yarn test:code",
    "test:integration": "node tests/integration-test.mjs",
    "test:coverage": "c8 --reporter=text --reporter=lcov node dist/index.js"
  },
  "version": "1.6.4"
}
